# Modele Whisper: tiny, base, small, medium, large-v3
# Plus le modele est grand, plus la transcription est precise mais lente
# large-v3 recommande pour le wolof (necessite ~10GB RAM)
# medium est un bon compromis (5GB RAM)
WHISPER_MODEL=large-v3

# Cle API Groq (GRATUITE) pour la correction automatique du texte
# Inscris-toi sur https://console.groq.com pour obtenir une cle gratuite
# Sans cle, la transcription fonctionne mais sans correction LLM
GROQ_API_KEY=gsk_votre_cle_ici
